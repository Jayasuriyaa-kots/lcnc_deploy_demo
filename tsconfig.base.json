{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "ES2022",
    "lib": ["ES2022", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@builder/*": ["apps/builder/src/app/*"],
      "@builder/report-builder/config": ["apps/builder/src/app/features/report-builder/config/report-builder.config.ts"],
      "@builder/report-builder/models": ["apps/builder/src/app/features/report-builder/models/report-builder.models.ts"],
      "@qo/models": ["libs/models/src/index.ts"],
      "@qo/models/*": ["libs/models/src/*"],
      "@quanta-ops/models": ["libs/models/src/index.ts"],
      "@quanta-ops/models/*": ["libs/models/src/*"],
      "@qo/auth-lib": ["libs/auth-lib/src/index.ts"],
      "@qo/auth-lib/*": ["libs/auth-lib/src/*"],
      "@quanta-ops/auth-lib": ["libs/auth-lib/src/index.ts"],
      "@quanta-ops/auth-lib/*": ["libs/auth-lib/src/*"],
      "@qo/api-client": ["libs/api-client/src/index.ts"],
      "@qo/api-client/*": ["libs/api-client/src/*"],
      "@quanta-ops/api-client": ["libs/api-client/src/index.ts"],
      "@quanta-ops/api-client/*": ["libs/api-client/src/*"],
      "@qo/ui-components": ["libs/ui-components/src/index.ts"],
      "@qo/ui-components/*": ["libs/ui-components/src/*"],
      "@quanta-ops/ui-components": ["libs/ui-components/src/index.ts"],
      "@quanta-ops/ui-components/*": ["libs/ui-components/src/*"],
      "@qo/ui-components/button": ["libs/ui-components/src/lib/primitives/button/index.ts"],
      "@qo/ui-components/card": ["libs/ui-components/src/lib/layout/card/index.ts"],
      "@qo/ui-components/connector-icon": ["libs/ui-components/src/lib/primitives/connector-icon/index.ts"],
      "@qo/ui-components/drawer": ["libs/ui-components/src/lib/overlay/drawer/index.ts"],
      "@qo/ui-components/form-field": ["libs/ui-components/src/lib/forms/form-field/index.ts"],
      "@qo/ui-components/input": ["libs/ui-components/src/lib/forms/input/index.ts"],
      "@qo/ui-components/metric-strip": ["libs/ui-components/src/lib/data-display/metric-strip/index.ts"],
      "@qo/ui-components/shell": ["libs/ui-components/src/lib/shell/index.ts"],
      "@qo/ui-components/status-dot": ["libs/ui-components/src/lib/primitives/status-dot/index.ts"],
      "@qo/ui-components/stepper": ["libs/ui-components/src/lib/navigation/stepper/index.ts"],
      "@qo/ui-components/table": ["libs/ui-components/src/lib/data-display/table/index.ts"],
      "@qo/ui-components/tabs": ["libs/ui-components/src/lib/layout/tabs/index.ts"],
      "@qo/ui-components/toast": ["libs/ui-components/src/lib/feedback/toast/index.ts"],
      "@qo/ui-components/toggle": ["libs/ui-components/src/lib/forms/toggle/index.ts"],
      "@qo/lang": ["libs/lang/src/index.ts"],
      "@qo/lang/*": ["libs/lang/src/*"],
      "@quanta-ops/lang": ["libs/lang/src/index.ts"],
      "@quanta-ops/lang/*": ["libs/lang/src/*"],
      "@quanta-ops/ui-components/button": ["libs/ui-components/src/lib/primitives/button/index.ts"],
      "@quanta-ops/ui-components/card": ["libs/ui-components/src/lib/layout/card/index.ts"],
      "@quanta-ops/ui-components/connector-icon": ["libs/ui-components/src/lib/primitives/connector-icon/index.ts"],
      "@quanta-ops/ui-components/drawer": ["libs/ui-components/src/lib/overlay/drawer/index.ts"],
      "@quanta-ops/ui-components/form-field": ["libs/ui-components/src/lib/forms/form-field/index.ts"],
      "@quanta-ops/ui-components/input": ["libs/ui-components/src/lib/forms/input/index.ts"],
      "@quanta-ops/ui-components/metric-strip": ["libs/ui-components/src/lib/data-display/metric-strip/index.ts"],
      "@quanta-ops/ui-components/shell": ["libs/ui-components/src/lib/shell/index.ts"],
      "@quanta-ops/ui-components/status-dot": ["libs/ui-components/src/lib/primitives/status-dot/index.ts"],
      "@quanta-ops/ui-components/stepper": ["libs/ui-components/src/lib/navigation/stepper/index.ts"],
      "@quanta-ops/ui-components/table": ["libs/ui-components/src/lib/data-display/table/index.ts"],
      "@quanta-ops/ui-components/tabs": ["libs/ui-components/src/lib/layout/tabs/index.ts"],
      "@quanta-ops/ui-components/toast": ["libs/ui-components/src/lib/feedback/toast/index.ts"],
      "@quanta-ops/ui-components/toggle": ["libs/ui-components/src/lib/forms/toggle/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
