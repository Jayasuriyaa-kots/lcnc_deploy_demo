{
  "name": "quanta-ops",
  "version": "0.0.0",
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=22.20.0 <23",
    "npm": ">=10.9.2 <11"
  },
  "scripts": {
    "build": "nx run-many -t build -p deployer,builder",
    "deployer": "nx serve deployer",
    "builder": "nx serve builder",
    "client": "nx serve client",
    "i18n:sync-form-builder": "node tools/generate-form-builder-en-json.mjs",
    "i18n:sync-workflow-builder": "node tools/generate-workflow-builder-en-json.mjs",
    "i18n:audit-form-builder": "node tools/audit-form-builder-i18n.mjs",
    "i18n:sync-datasources": "node tools/generate-datasources-en-json.mjs",
    "i18n:audit-datasources": "node tools/audit-datasources-i18n.mjs",
    "i18n:sync-report-builder": "node tools/generate-report-builder-en-json.mjs",
    "i18n:audit-report-builder": "node tools/audit-report-builder-i18n.mjs",
    "i18n:sync-page-builder": "node tools/generate-page-builder-en-json.mjs",
    "i18n:audit-page-builder": "node tools/audit-page-builder-i18n.mjs",
    "i18n:audit-workflow-builder": "node tools/audit-workflow-builder-i18n.mjs",
    "i18n:sync-deployer": "node tools/generate-deployer-en-json.mjs",
    "i18n:audit-deployer": "node tools/audit-deployer-i18n.mjs",
    "i18n:sync-all": "npm run i18n:sync-form-builder && npm run i18n:sync-report-builder && npm run i18n:sync-page-builder && npm run i18n:sync-datasources && npm run i18n:sync-workflow-builder && npm run i18n:sync-deployer",
    "i18n:audit-global": "node tools/audit-global-i18n.mjs",
    "i18n:audit-all": "node tools/audit-all-i18n.mjs"
  },
  "dependencies": {
    "@angular/animations": "21.2.11",
    "@angular/cdk": "21.2.11",
    "@angular/common": "21.2.11",
    "@angular/compiler": "21.2.11",
    "@angular/core": "21.2.11",
    "@angular/forms": "21.2.11",
    "@angular/platform-browser": "21.2.11",
    "@angular/platform-browser-dynamic": "21.2.11",
    "@angular/router": "21.2.11",
    "@jsverse/transloco": "^7.6.1",
    "@kolkov/angular-editor": "3.0.5",
    "chart.js": "4.5.1",
    "jspdf": "4.2.1",
    "jspdf-autotable": "5.0.8",
    "jwt-decode": "4.0.0",
    "ng2-charts": "10.0.0",
    "rxjs": "7.8.2",
    "tslib": "2.8.1",
    "zone.js": "0.16.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "21.2.11",
    "@angular/cli": "21.2.11",
    "@angular/compiler-cli": "21.2.11",
    "@types/jasmine": "5.1.15",
    "jasmine-core": "5.13.0",
    "karma": "6.4.4",
    "karma-chrome-launcher": "3.2.0",
    "karma-coverage": "2.2.1",
    "karma-jasmine": "5.1.0",
    "karma-jasmine-html-reporter": "2.2.0",
    "nx": "^22.6.5",
    "typescript": "5.9.3"
  },
  "overrides": {
    "follow-redirects": "1.16.0",
    "hono": "4.12.21",
    "ip-address": "10.2.0",
    "postcss": "8.5.12",
    "tmp": "0.2.6",
    "uuid": "14.0.0",
    "webpack-dev-server": "5.2.4",
    "ws": "8.20.1",
    "yaml": "2.8.3"
  }
